{
  "manifest_version": 3,
  "name": "Valet",
  "version": "1.4.0",
  "description": "Auto-name and route AI-generated downloads to the right folder. Smart naming from prompts, tab group routing.",

  "permissions": [
    "downloads",
    "notifications",
    "storage",
    "tabs",
    "tabGroups"
  ],

  "host_permissions": [
    "http://localhost:27182/*"
  ],

  "background": {
    "service_worker": "background.js"
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_script.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Valet",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
